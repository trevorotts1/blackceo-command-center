{
  "name": "mission-control",
  "version": "6.0.65",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p ${PORT:-4000}",
    "build": "next build",
    "start": "bash scripts/cc-start.sh",
    "lint": "next lint",
    "test:unit": "node --import tsx --import ./tests/setup/no-owner-telegram.ts --test $(ls tests/unit/*.test.ts | grep -v -E 'deep-health\\.test\\.ts|cc-probe-pm2\\.test\\.ts|floor-department-invariant\\.test\\.ts|department-optout-board-wiring\\.test\\.ts|middleware-same-origin-board\\.test\\.ts|middleware-401-telemetry\\.test\\.ts|unauthorized-401-health-surface\\.test\\.ts|provider-key-auth-store\\.test\\.ts|ceo-chat-upload-validation\\.test\\.ts|ceo-chat-config\\.test\\.ts|ceo-chat-store\\.test\\.ts|trust-engine-ceo-chat-channel\\.test\\.ts|ceo-chat-gateway-forward\\.test\\.ts|ceo-chat-gateway-transport\\.test\\.ts|ceo-chat-gateway-session-isolation\\.test\\.ts|skill6-board-projection\\.test\\.ts|mc-board-producer-projection\\.test\\.ts|u12-a-persona-grounding-health\\.test\\.ts|u62-thinking-level-mapping\\.test\\.ts|ceo-chat-message-route-passthrough\\.test\\.ts|migration-110-ceo-chat-usage-columns\\.test\\.ts')",
    "test:deep-health": "vitest run tests/unit/deep-health.test.ts",
    "test:skill6-board-projection": "vitest run tests/unit/skill6-board-projection.test.ts",
    "test:mc-board-producer-projection": "vitest run tests/unit/mc-board-producer-projection.test.ts",
    "test:persona-grounding-health": "vitest run tests/unit/u12-a-persona-grounding-health.test.ts",
    "test:vitest": "vitest run",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:prove-zhe-web": "node --import tsx --test tests/e2e/prove-zhe-web.e2e.mjs",
    "test:401-e2e": "node tests/e2e/prove-401-telemetry.e2e.mjs",
    "test:e2e:interview-lock": "playwright test --config=playwright.interview-lock.config.ts",
    "test:e2e:create-task": "playwright test --config=playwright.create-task.config.ts",
    "test:e2e:my-ai-ceo": "playwright test --config=playwright.my-ai-ceo.config.ts",
    "test:e2e:agent-navigation": "playwright test --config=playwright.agent-navigation.config.ts",
    "test:e2e:home-dashboard-fault": "playwright test --config=playwright.home-dashboard-fault.config.ts",
    "test:prove-zhe-web:local": "node --experimental-strip-types --import ./tests/e2e/ts-register.mjs --test tests/e2e/prove-zhe-web.e2e.mjs",
    "test:sync:branding": "npx tsx scripts/sync-branding-questions-test.ts",
    "lint:interview-jargon": "npx tsx scripts/lint-interview-jargon.ts",
    "lint:ceo-chat-colors": "npx tsx scripts/lint-ceo-chat-colors.ts",
    "test:smoke:sop-auto-replace": "npx tsx scripts/smoke-test-sop-auto-replace.ts",
    "test:smoke:sop-authoring": "npx tsx scripts/smoke-test-sop-authoring.ts",
    "db:push": "tsx src/lib/db/migrate.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:seed:sops": "tsx scripts/seed-starter-sops.ts",
    "db:embed:sops": "tsx scripts/backfill-sop-embeddings.ts",
    "db:import:role-library": "tsx scripts/import-role-library.ts",
    "audit:home-dashboard-fix": "tsx scripts/audit-home-dashboard-fix.ts",
    "audit:responsive": "node scripts/responsive-audit.mjs",
    "audit:responsive:inventory": "node scripts/responsive-route-inventory.mjs",
    "audit:responsive:gate": "node scripts/responsive-gate.mjs",
    "db:backup": "python3 -c \"import sqlite3; c=sqlite3.connect('mission-control.db', timeout=5); c.execute('PRAGMA wal_checkpoint(TRUNCATE)'); c.close()\" && cp mission-control.db mission-control.db.backup && echo 'Backed up to mission-control.db.backup'",
    "db:restore": "cp mission-control.db.backup mission-control.db && echo 'Restored from backup'",
    "db:reset": "rm -f mission-control.db mission-control.db-* && npm run db:seed",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@hello-pangea/dnd": "^17.0.0",
    "@types/node-cron": "^3.0.11",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "css-tree": "^3.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.21",
    "node-cron": "^4.2.1",
    "playwright": "^1.58.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "source-map-js": "^1.2.1",
    "uuid": "^11.0.4",
    "ws": "^8.18.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^20.17.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.21",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
