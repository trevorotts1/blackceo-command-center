{
  "name": "mission-control",
  "version": "4.40.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p ${PORT:-4000}",
    "build": "next build",
    "start": "next start -p ${PORT:-4000}",
    "lint": "next lint",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:deep-health": "vitest run tests/unit/deep-health.test.ts",
    "test:vitest": "vitest run",
    "test:sync:branding": "npx tsx scripts/sync-branding-questions-test.ts",
    "test:smoke:sop-auto-replace": "npx tsx scripts/smoke-test-sop-auto-replace.ts",
    "test:smoke:sop-authoring": "npx tsx scripts/smoke-test-sop-authoring.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:seed:sops": "tsx scripts/seed-starter-sops.ts",
    "db:import:role-library": "tsx scripts/import-role-library.ts",
    "db:backup": "sqlite3 mission-control.db 'PRAGMA wal_checkpoint(TRUNCATE);' && cp mission-control.db mission-control.db.backup && echo 'Backed up to mission-control.db.backup'",
    "db:restore": "cp mission-control.db.backup mission-control.db && echo 'Restored from backup'",
    "db:reset": "rm -f mission-control.db mission-control.db-* && npm run db:seed",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@hello-pangea/dnd": "^17.0.0",
    "@types/node-cron": "^3.0.11",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "css-tree": "^3.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.21",
    "node-cron": "^4.2.1",
    "playwright": "^1.58.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "source-map-js": "^1.2.1",
    "uuid": "^11.0.4",
    "ws": "^8.18.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^20.17.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
