# ====================================
# Mission Control Configuration
# ====================================

# Database path (default: ./mission-control.db)
DATABASE_PATH=./mission-control.db

# ====================================
# Branding Configuration
# ====================================

# Custom logo URL (optional)
# Set this to use your own logo instead of the default
# Must be a publicly accessible URL to an image file (PNG, SVG, etc.)
# Recommended height: 40px, transparent background preferred
# NEXT_PUBLIC_LOGO_URL=https://your-cdn.com/your-logo.png

# ====================================
# OpenClaw Gateway Configuration
# ====================================

# OpenClaw Gateway URL (default: ws://127.0.0.1:18789)
# Leave at the loopback default when the command center runs in the SAME
# container/host as the gateway (the normal install). Only set this when the
# gateway lives on a different host — and reach it over the Cloudflare Tunnel,
# e.g. wss://gateway.example.com. (Tailscale is NOT used in this stack.)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw Gateway authentication token (required for remote connections)
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ── My AI CEO (BETA) — P5-01 ────────────────────────────────────────────────
# The "My AI CEO" dashboard surface: talk directly to your on-box agent, upload
# documents/images/videos, watch progress. It forwards through the OpenClaw
# gateway above (never bypasses it) and degrades to "use Telegram meanwhile" when
# the gateway is down. Feature-flagged BETA: DEFAULT ON. Set to "false" to hide it
# entirely on a box. Uploads land under <workspace>/inbox/ceo-chat/<date>/.
# MY_AI_CEO_BETA=true
# Optional tunables (ms) for the gateway forward: initial-connect / whole-reply.
# CEO_CHAT_CONNECT_TIMEOUT_MS=8000
# CEO_CHAT_REPLY_TIMEOUT_MS=120000

# Persistent path for the Bridge device identity (the ed25519 keypair the
# gateway pairs with). Defaults to /data/.openclaw/mission-control/identity on
# VPS Docker (survives `docker compose up -d --force-recreate`) and
# ~/.mission-control/identity on Mac Mini. Override only for a custom mount.
# BCC_DEVICE_IDENTITY_DIR=/data/.openclaw/mission-control/identity

# Disable the on-boot Bridge pairing bootstrap (the single connect attempt that
# registers this device as a pending pairing request on the gateway). Set to 1
# in CI or on a box with no gateway.
# DISABLE_BRIDGE_BOOTSTRAP=0

# Bridge install type — controls which CLI pills the Bridge shows. `vps` shows
# only OpenClaw (the Mac-desktop CLIs are not installed in the container);
# `mac` shows all. Defaults to auto-detect (OPENCLAW_PLATFORM env, then the
# /data/.openclaw VPS marker).
# BCC_INSTALL_TYPE=vps

# ====================================
# Planning Configuration
# ====================================

# Planning timeout in milliseconds (default: 30000 = 30 seconds)
# How long to wait for Charlie to respond to a planning question
PLANNING_TIMEOUT_MS=30000

# Planning poll interval in milliseconds (default: 2000 = 2 seconds)
# How frequently to poll for updates from OpenClaw during planning
PLANNING_POLL_INTERVAL_MS=2000

# ====================================
# Workspace Configuration
# ====================================

# Mission Control API URL (auto-detected if not set)
# Override for remote access or custom deployments
# MISSION_CONTROL_URL=http://localhost:4000

# Per-client PUBLIC dashboard URL — the base the interview resume-nudge builds
# {link} = <this>/onboarding/resume/<slug> from (P3-5). Set one per client, e.g.
# https://<client>.zerohumanworkforce.com . Falls back to MISSION_CONTROL_URL.
# Mirrors the env the box-side shared-utils/nudge-incomplete-interviews.py reads.
# OPENCLAW_DASHBOARD_URL=https://<client>.zerohumanworkforce.com

# Interview re-engagement nudge sweep (P3-5). OPT-IN and dormant by default
# (repo-only until fleet rollout is released). Set to 1 to arm the hourly worker
# that DMs a paused-interview owner one resume link per idle tier.
# INTERVIEW_NUDGE_SWEEP_ENABLED=1
# Idle tiers in hours before each one-shot nudge (default 24,72,168):
# INTERVIEW_NUDGE_TIER_HOURS=24,72,168
# Kill switch (overrides ENABLED):
# DISABLE_INTERVIEW_NUDGE_SWEEP=1

# Base workspace directory (default: ~/Documents/Shared)
# All Mission Control files are stored here
# WORKSPACE_BASE_PATH=~/Documents/Shared

# Projects directory (default: ~/Documents/Shared/projects)
# Each project gets a unique folder here
# PROJECTS_PATH=~/Documents/Shared/projects

# ====================================
# Security Configuration
# ====================================

# API authentication token (required for production)
# If not set, authentication is DISABLED (local dev mode only)
# Generate with: openssl rand -hex 32
MC_API_TOKEN=

# Webhook signature secret for agent-completion webhook
# If not set, signature validation is DISABLED (local dev mode only)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ====================================
# v4.0 Deployment Configuration
# ====================================

# Cloudflare Access enforcement (PRD 3.1)
# Set to "true" in production so the middleware rejects requests
# that are missing the CF-Access-Authenticated-User-Email header.
# Leave unset / "false" for local dev (no CF in front).
REQUIRE_CF_ACCESS=false

# Demo seed content (PRD 3.5) — OPT-IN (audit ISSUE #1)
# The seed inserts ONLY structural rows (guarded master orchestrator agent,
# department memory) by default. Set DEMO_SEED=true ONLY for the public
# github.com/crshdn/mission-control demo deployment to also insert the 4 demo
# agents / tasks / events / messages. Real client deployments leave it UNSET
# so the board boots structurally empty for Skill 23 to populate.
# (Replaces the old SKIP_DEMO_SEED opt-out, which was never set and so shipped
#  demo content onto every client board.)
# DEMO_SEED=true

# White-label company name fallback (PRD 3.7)
# Used when the companies table is empty. Leave unset for true
# white-label (UI shows "Welcome to your Command Center").
# COMPANY_NAME=
# COMPANY_SLUG=

# Cron job shared secret (PRD 5.3)
# Bearer token that POST /api/cron/refresh-models verifies before
# triggering a manual refresh. Generate with: openssl rand -hex 32
CRON_SECRET=

# Departments seed path (PRD 3.5 bootstrap)
# Absolute path to a JSON file listing departments to seed on first
# boot. Defaults to ./config/departments.json.
# DEPARTMENTS_CONFIG_PATH=

# ====================================
# v4.0 Platform Roots (PRD 3.6)
# ====================================

# Platform override. Auto-detected from hostname / filesystem when
# unset. Accepts: mac-mini | vps-docker
# OPENCLAW_PLATFORM=

# OpenClaw root directory. Defaults to /data/.openclaw on VPS Docker
# and ~/.openclaw on Mac Mini.
# OPENCLAW_ROOT=

# OpenClaw per-company workspace root. Used by Bridge sessions, Studio
# jobs, and Workspace buckets. Defaults to ${OPENCLAW_ROOT}/workspace.
# OPENCLAW_COMPANY_ROOT=
# OPENCLAW_WORKSPACE_PATH=

# Operator vault root (Obsidian-style markdown vault). Research,
# Journal, Goals, Web Agent, and Studio mirror outputs here.
# Defaults to ~/clawd on Mac Mini, /data/.openclaw/vault on VPS.
# VAULT_ROOT=

# Operator scratch root (per-agent ephemeral CLI cwd + screenshots).
# Defaults to ~/clawd/scratch on Mac Mini, /data/.openclaw/scratch on VPS.
# SCRATCH_ROOT=

# ====================================
# v4.0 Model Provider API Keys (PRD 5.2, Wave 2)
# ====================================
# Each provider's key follows the {SLUG_UPPER}_API_KEY convention.
# The weekly refresh cron (PRD 5.3) reads these to populate model_registry.
# Leave a key blank to mark that provider as "unknown" in System Status.

# ====================================
# Semantic SOP Search — Provider-flexible embedding
# ====================================
#
# Semantic SOP search auto-selects an embedding provider based on which key is
# present. Set ONE of the following and the SOP suggest endpoint activates —
# no other configuration required. When no key is set, the system falls back to
# pure keyword matching (no error, no crash).
#
# PROVIDER AUTO-DETECTION ORDER:
#   1. OPENAI_API_KEY present  → OpenAI text-embedding-3-small (1536-dim)
#   2. Google key present      → Google gemini-embedding-001 (3072-dim, FREE tier available)
#   3. Neither                 → keyword-only fallback
#
# FORCE A SPECIFIC PROVIDER (optional override):
#   SOP_EMBEDDING_PROVIDER=openai    # force OpenAI even when Google key is also set
#   SOP_EMBEDDING_PROVIDER=google    # force Google even when OpenAI key is also set
#
# GOOGLE-ONLY CLIENTS (no OpenAI key needed):
#   Set GOOGLE_API_KEY (or GOOGLE_AI_STUDIO_API_KEY or GEMINI_API_KEY) and
#   semantic SOP search activates using gemini-embedding-001 (3072-dim).
#   No OPENAI_API_KEY required.
#
# AFTER SETTING A KEY — run the one-time backfill to embed existing SOPs:
#   tsx scripts/backfill-sop-embeddings.ts
#   New SOPs are embedded automatically on create/update/import.
#   Backfill is resumable — re-run safely after quota limits or interruptions.
#
# NOTE: OpenAI and Google embeddings live in different vector spaces (1536 vs
# 3072 dims). If you switch providers, re-run the backfill — the system skips
# cross-provider comparisons automatically (dimension guard).
#
# SOP_EMBEDDING_PROVIDER=

# OpenAI (chat, embeddings, images, TTS).
# https://platform.openai.com/api-keys
#
# When OPENAI_API_KEY is set and GOOGLE_API_KEY is absent, OpenAI is used for
# SOP embeddings (text-embedding-3-small, 1536-dim, ~$0.02/1M tokens).
# Keys are server-side only (never NEXT_PUBLIC_).
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude chat + Web Agent computer use).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_API_VERSION=2023-06-01

# Google Gemini (chat, vision, AND SOP embeddings).
# https://aistudio.google.com/apikey
# Accepts GOOGLE_API_KEY, GOOGLE_AI_STUDIO_API_KEY, or GEMINI_API_KEY (any one).
#
# ⚑ SEMANTIC SOP SEARCH (Google-only path):
#   When OPENAI_API_KEY is absent, a Google key here activates SOP semantic
#   search via gemini-embedding-001 (3072-dim). No OpenAI key needed.
#   After adding a Google key, run: tsx scripts/backfill-sop-embeddings.ts
GOOGLE_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_API_KEY=
# GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# xAI Grok (chat + Live Search for Research sub-module).
# https://console.x.ai
X_AI_API_KEY=
# X_AI_BASE_URL=https://api.x.ai/v1

# Perplexity (grounded web search for the Research sub-module — highest
# preference). https://docs.perplexity.ai  Accepts PERPLEXITY_API_KEY or PPLX_API_KEY.
PERPLEXITY_API_KEY=
# PPLX_API_KEY=

# OpenRouter (multi-provider gateway, also used by FCC).
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_X_TITLE=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Z.AI (GLM family chat).
# https://open.bigmodel.cn or z.ai console
ZAI_API_KEY=
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Moonshot (Kimi chat). Set MOONSHOT_BASE_URL to api.moonshot.ai for
# the international endpoint or api.moonshot.cn for the .cn endpoint.
MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# MiniMax (chat + video via curated catalog).
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.chat/v1

# Kie.ai (image / video generation in Studio).
# Accepts either KIE_AI_API_KEY or KIE_API_KEY.
KIE_AI_API_KEY=
KIE_API_KEY=
# KIE_BASE_URL=https://api.kie.ai/api/v1

# Fal.ai (image / video generation in Studio).
# Accepts either FAL_AI_API_KEY or FAL_KEY (per Studio note 5).
FAL_AI_API_KEY=
FAL_KEY=
# FAL_RUN_BASE_URL=https://fal.run
# FAL_QUEUE_BASE_URL=https://queue.fal.run
# FAL_EXTRA_MODELS=

# Replicate (image / video generation in Studio).
# Accepts either REPLICATE_API_TOKEN or REPLICATE_API_KEY.
REPLICATE_API_TOKEN=
REPLICATE_API_KEY=
# REPLICATE_BASE_URL=https://api.replicate.com/v1
# REPLICATE_MODEL_LIMIT=200

# ElevenLabs (TTS in Studio + Call Mode).
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# Ollama Cloud (hosted Ollama models).
OLLAMA_CLOUD_API_KEY=
# Base URL. Leave unset to use the default (https://ollama.com) — correct for
# any box with an OLLAMA_CLOUD_API_KEY. Do NOT append '/api': callers add the
# '/v1/...' path themselves, and '/api/v1/...' returns HTTP 404 upstream.
# Optional override: a signed-in LOCAL Ollama daemon, which is the authenticated
# conduit to Ollama Cloud (':cloud'-tagged models still execute cloud-side
# through it — loopback here does NOT mean on-device inference). Only set this
# on a box that actually runs a signed-in daemon; on a Docker/VPS box with no
# daemon it yields ECONNREFUSED on every call.
# OLLAMA_CLOUD_BASE_URL=http://127.0.0.1:11434

# ====================================
# v4.0 Call Mode TTS (SCOPE-ADDITION Section 6, Track B8)
# ====================================

# Default TTS provider when the operator has not picked one in the UI.
# Accepts: openai | elevenlabs | fish-audio | xai | browser
DEFAULT_CALL_TTS_PROVIDER=openai

# OpenAI TTS voice + model (used when DEFAULT_CALL_TTS_PROVIDER=openai
# or the operator selects OpenAI in Call Mode).
# Voices: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# ElevenLabs voice id (used when DEFAULT_CALL_TTS_PROVIDER=elevenlabs).
# Pick a voice id from your ElevenLabs voice library.
ELEVENLABS_VOICE_ID=

# Fish Audio TTS (reserved, not yet wired). Adding a key here lets the
# Call Mode picker show Fish Audio as configured.
FISH_AUDIO_API_KEY=

# ====================================
# v4.0 Research sub-module (SCOPE-ADDITION Section 5, Track B7)
# ====================================
#
# As of v4.1.5 Research is PROVIDER-AGNOSTIC. It auto-discovers a search
# provider from the keys above and selects ONE, in this preference order:
#
#     PERPLEXITY_API_KEY  >  OPENAI_API_KEY  >  OLLAMA_CLOUD_API_KEY  >  X_AI_API_KEY
#
# Set ANY ONE of those and the module goes live (the page names the selected
# provider). Set none and the page shows an honest empty-state telling the
# operator which key to add — never a dead box.

# Tavily fallback search provider (used by the SOP auto-replace path; NOT the
# Research sub-module, which uses the provider-agnostic selector above).
TAVILY_API_KEY=

# ====================================
# v4.0 Operator Bridge CLI Paths (PRD 4.3, Track B2)
# ====================================
# Absolute paths to the operator CLI binaries. If unset the spawn
# falls back to the bare binary name on PATH. The install scripts in
# PRD Section 6 export these into ~/.zshrc on first run.

# BCC_CLAUDE_BIN=/usr/local/bin/claude
# BCC_CODEX_BIN=/usr/local/bin/codex
# BCC_ANTIGRAVITY_BIN=/usr/local/bin/agy
# BCC_HERMES_BIN=/usr/local/bin/hermes
# BCC_GEMINI_BIN=/usr/local/bin/gemini

# Free Claude Code proxy (PRD 4.3, fccProxyEnv).
# FCC_SERVER_URL=http://127.0.0.1:8082
# FCC_API_KEY=fcc-proxy

# ====================================
# v4.0 Test Fixtures (offline CI / local dev)
# ====================================
# Set any of these to an absolute path of a canned JSON response and
# the matching route will skip the upstream network call. Lets the UI
# exercise the full code path with no API key or live provider.

# TAVILY_FIXTURE_JSON_PATH=
# X_AI_FIXTURE_JSON_PATH=
# GEMINI_FIXTURE_JSON_PATH=
# WEB_AGENT_FIXTURE_PATH=
# STUDIO_FIXTURE_IMAGE_PATH=
# STUDIO_FIXTURE_VIDEO_PATH=
# STUDIO_FIXTURE_AUDIO_PATH=

# ====================================
# v4.0 Misc
# ====================================

# Public app URL used in generated emails / Telegram links.
# NEXT_PUBLIC_APP_URL=http://localhost:4000

# Telegram bot token (notifications + agent pairing).
TELEGRAM_BOT_TOKEN=

# Disable the SOP auto-replace Telegram broadcast (advanced).
# SOP_AUTO_REPLACE_TELEGRAM_DISABLED=false

# Legacy demo mode flag (kept for compatibility; DEMO_SEED is preferred — see above).
# DEMO_MODE=false

# ====================================
# U117 (E6-3/G9) — Comms-artifact QC conformance gate
# ====================================
# Extends runQCOnReview's producer-scorecard contract (src/lib/qc-scorer.ts;
# see QC_PRODUCER_SCORECARD_ENABLED, which this flag builds on but does not
# require independently) with a comms-artifact-specific requirement: for an
# outside-world communication (page/blog/email/sms/social — master spec v2
# §E6-3), review→done additionally requires the ONB (openclaw-onboarding)
# leg's `grade_comms_conformance()` verdict to PASS — per-part persona
# governance (U115), topic considered, audience confirmed (U116), and blend
# actually used (semantic). A producer that ran that check posts
# `comms_qc_passed` (+ optional `comms_hard_misses`) onto the SAME
# `post_qc_score()` metadata row as its base gate; an explicit `false`
# blocks promotion (the reason + gaps name which check(s) failed), an
# absent/non-boolean value (no producer ran the check, or the ONB SKIP
# shape) never blocks.
# OFF by default (unset / anything other than "1" or "true"). Read LIVE
# per-call by isCommsQcConformanceEnabled() — same reload semantics as
# QC_PRODUCER_SCORECARD_ENABLED (a value newly added to .env.local requires
# a Command Center restart to reach the running process).
# Revert contract: unset this var -> the comms fields on any posted
# scorecard are never read, byte-identical to pre-U117 review->done
# behavior.
# COMMS_QC_CONFORMANCE=1

# ====================================
# Security Notes
# ====================================
#
# NEVER commit this file with real values!
# This is a template - copy to .env.local and configure:
#
#   cp .env.example .env.local
#
# Then edit .env.local with your actual values.
# .env.local is gitignored and will not be committed.
