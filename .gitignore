# Backups
*.backup
*.bak
*.bak-*
*.db.backup

# FIX-RESCUE-12: retired backups/archive + legacy bridge live outside git.
# _archive/ holds relocated *.bak* and the retired rescue-rangers-bridge.py
# (a historical secret carrier); it must never be committed to this
# fleet-wide repo. Belt-and-braces alongside the *.bak rules above.
fleet-heartbeat/scripts/_archive/
fleet-heartbeat/scripts/rescue-rangers-bridge.py
fleet-heartbeat/scripts/rescue-rangers-bridge.py.*

# Build backups
.next-backup/
test-results/

# graphify (knowledge-graph map) — generated output, never committed
graphify-out/
__pycache__/

# operator-local client roster — the REAL client name/chat-ID/GHL-ID denylist
# consumed at runtime by the leak-detection gates. Must NEVER be committed; only
# the scripts/client-roster.example.txt template (fake placeholders) is tracked.
.openclaw-client-roster.txt
client-roster.txt

# Per-box runtime configuration. The application generates these from the
# tracked *.example.json templates and then mutates only the ignored copies.
# Existing installs are migrated by update.sh.
/config/company-config.json
/config/departments.json
/config/board-slas.json
/public/logo-config.json
/.last-update-check
