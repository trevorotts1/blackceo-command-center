# Command Center Demo Pack — DASHBOARD instance (Profile 2: the destination demo).
#
# Authored FROM SCRATCH. ZERO provider keys, NO real gateway. Uses the repo's
# existing DEMO_MODE=true so the whole instance is public + read-only (middleware
# 403s every non-GET API call and skips the interview shell-lock), which makes it
# safe as a link a prospect clicks in a follow-up email.
#
# Dynamic per-instance values are assembled at runtime by demo.ecosystem.config.cjs
# + reset-demo.sh. qc-demo.sh verifies no keys / no real gateway / read-only 403.

NODE_ENV=production
CC_PORT=4601

# Read-only public prospect link (look, don't touch).
DEMO_MODE=true

# DEAD gateway (never the real 18789) — no LLM, no tokens, no real agent.
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:1

COMPANY_NAME=Harbor & Oak Candle Co.

# ── NO PROVIDER KEYS BELOW THIS LINE (enforced by qc-demo.sh) ──
