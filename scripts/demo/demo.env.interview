# Command Center Demo Pack — INTERVIEW instance (Profile 1: the journey demo).
#
# Authored FROM SCRATCH — never copied from a production .env.local. Contains
# ZERO provider keys and NO real gateway. These are the static, safety-critical
# settings; the dynamic per-instance values (DATABASE_PATH, OPENCLAW_WORKSPACE_ROOT,
# OPENCLAW_SKILL23_SCRIPTS, OPENCLAW_COMPANY_ROOT, HOME, MC_INTERVIEW_COOKIE_SECRET)
# are assembled at runtime by demo.ecosystem.config.cjs + reset-demo.sh so paths
# stay machine-relative and the cookie secret rotates on every reset.
#
# qc-demo.sh verifies this file (and the live pm2 env) carries no known provider
# key and no real gateway URL.

NODE_ENV=production
CC_PORT=4600

# DEAD gateway — deliberately NOT the real local gateway (ws://127.0.0.1:18789).
# Conversational interview turns 503 and the UI degrades to the structured cards
# ("Your interviewer is taking a moment. Your answers are safe."). No LLM, no
# tokens, no real agent session — ever.
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:1

COMPANY_NAME=Harbor & Oak Candle Co.

# This instance is INTERACTIVE (the interview POSTs answers) so it is NOT
# DEMO_MODE. All writes land in the demo sandbox only (own DB + own workspace +
# stubbed Skill-23 scripts). External API auth stays fail-closed (no MC_API_TOKEN);
# same-origin browser use works without a token. REQUIRE_CF_ACCESS is left OFF for
# local runs; in production this hostname sits behind Cloudflare Access.

# ── NO PROVIDER KEYS BELOW THIS LINE (enforced by qc-demo.sh) ──
# (no ANTHROPIC_API_KEY, no OPENAI_API_KEY, no GEMINI/GOOGLE key, no FISH_AUDIO_KEY,
#  no TELEGRAM_BOT_TOKEN, no TAVILY_API_KEY, no GHL/PIT token, no webhook URLs.)
