# scripts/demo/demo.env.interview — committed reference template (SPEC §1)
#
# Human-readable mirror of the env that scripts/demo/demo.ecosystem.config.cjs
# injects into the `blackceo-cc-demo-interview` app. It is ALSO the qc-demo scan
# target. Fictional / demo-only values ONLY — never a real key.
#
# Source it from the repo root ($REPO) for a manual `next start`:
#     cd "$REPO"
#     set -a; source scripts/demo/demo.env.interview; set +a
#     npx next start -p 4600 -H 127.0.0.1
# (paths below are $PWD-relative so they resolve against $REPO at source time.)

NODE_ENV=production

# ── Ports — interview instance ───────────────────────────────────────────────
PORT=4600
CC_PORT=4600

# ── Dead gateway ON PURPOSE (NOT 18789) ──────────────────────────────────────
# ws://127.0.0.1:1 is an unreachable port: conversational/LLM turns 503 and the
# app degrades gracefully to structured cards. Never point this at the real
# gateway (ws://127.0.0.1:18789).
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:1

# ── Skill-23 seam pinned to the committed, side-effect-free demo stubs ───────
OPENCLAW_SKILL23_SCRIPTS=$PWD/scripts/demo/skill23-stubs

# ── Runtime data (gitignored .runtime/) ──────────────────────────────────────
# Override DEMO_DATA_ROOT to relocate; these defaults live under $REPO.
DATABASE_PATH=$PWD/scripts/demo/.runtime/interview/mission-control.db
OPENCLAW_WORKSPACE_ROOT=$PWD/scripts/demo/.runtime/interview/workspace

# ── Cookie secret — PLACEHOLDER ONLY ─────────────────────────────────────────
# The REAL rotated value lives only in the gitignored runtime file
# ($DEMO_DATA_ROOT/cookie-secret.txt), rewritten by reset-demo.sh via
# `openssl rand -hex 32`. This committed token is intentionally non-secret.
MC_INTERVIEW_COOKIE_SECRET=__rotated_at_reset__

# ── Demo-only webhook secret ─────────────────────────────────────────────────
# NOT the real WEBHOOK_SECRET — cannot authenticate against any production box.
WEBHOOK_SECRET=demo-only-webhook-secret-not-real

# ── Branding ─────────────────────────────────────────────────────────────────
COMPANY_NAME=Harbor & Oak Candle Co.

# ── Cloudflare Access enforcement OFF for the local demo ─────────────────────
REQUIRE_CF_ACCESS=false

# ── DEMO_MODE intentionally UNSET for the interview instance ─────────────────
# The interview must accept POSTs so the live interview can write. Do NOT set
# DEMO_MODE here (setting it would make this a read-only instance).

# ═════════════════════════════════════════════════════════════════════════════
# NO PROVIDER KEYS — intentionally empty
# ─────────────────────────────────────────────────────────────────────────────
# The following are DELIBERATELY ABSENT. The demo runs with ZERO provider
# credentials; any LLM/conversational turn degrades gracefully to cards. Never
# add a real value for any of these (qc-demo.sh fails the build if you do):
#   ANTHROPIC_API_KEY
#   OPENAI_API_KEY
#   GOOGLE_API_KEY / GEMINI_API_KEY
#   TELEGRAM_BOT_TOKEN
#   FISH_AUDIO_API_KEY
#   TAVILY_API_KEY
#   OPENROUTER_API_KEY
#   OLLAMA_HOST / OLLAMA_API_KEY
#   PODBEAN_CLIENT_ID / PODBEAN_CLIENT_SECRET
#   GHL_API_KEY / HIGHLEVEL_API_KEY
#   TWILIO_AUTH_TOKEN
#   SENDGRID_API_KEY / SMTP_PASSWORD
#   MC_API_TOKEN
#   OPENCLAW_GATEWAY_TOKEN
#   CF_ACCESS_CLIENT_ID / CF_ACCESS_CLIENT_SECRET
# ═════════════════════════════════════════════════════════════════════════════
